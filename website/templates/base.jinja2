<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}LinkKeys{% endblock %}</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            line-height: 1.6;
            color: #333;
            max-width: 800px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }
        h1 { margin-bottom: 0.5rem; color: #1a1a2e; }
        h2 { margin-top: 1.5rem; margin-bottom: 0.5rem; color: #16213e; }
        p { margin-bottom: 1rem; }
        a { color: #0f3460; }
        a:hover { color: #e94560; }
        code { background: #f4f4f4; padding: 0.2em 0.4em; border-radius: 3px; font-size: 0.9em; }
        pre { background: #f4f4f4; padding: 1rem; border-radius: 5px; overflow-x: auto; margin-bottom: 1rem; }
        pre code { background: none; padding: 0; }
        footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid #eee; font-size: 0.85rem; color: #666; }
    </style>
</head>
<body>
    <main>
        {% block content %}{% endblock %}
    </main>
    <footer>
        <p>LinkKeys is a <a href="https://github.com/catalystcommunity">Catalyst Community</a> project.</p>
    </footer>
</body>
</html>
