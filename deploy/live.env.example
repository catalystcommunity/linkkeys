# Copy to ~/linkkeys/env and edit. This holds per-admin, per-host specifics so
# they stay OUT of the repo. deploy/live.sh sources it.

# Cluster access (kubeconfig path). Defaults to ~/.foundry/kubeconfig.
KUBECONFIG="$HOME/.foundry/kubeconfig"

# The Kubernetes namespace and Helm release for this instance.
NAMESPACE="linkkeys-squizzlezig"
RELEASE="linkkeys-squizzlezig"

# The domain this IDP is authoritative for.
DOMAIN="squizzlezig.com"

# Path to your values overlay (kept here, next to this env file, not in the repo).
VALUES="$HOME/linkkeys/values-squizzlezig.yaml"

# Where encrypted backups are written. Keep this on durable, ideally offline-able
# storage (it is the only copy of your domain identity outside the cluster).
BACKUP_DIR="$HOME/linkkeys/backups"

# Optional: a file containing the backup key (hex) for unattended restores.
# Leave unset to be prompted. NEVER commit this.
# BACKUP_KEY_FILE="$HOME/linkkeys/backup.key"

# Optional: the public IP your gateway is reachable on, used in the DNS hint.
PUBLIC_IP="75.169.10.57"

# Optional: pin a specific image tag (e.g. for rollback). Defaults to chart appVersion.
# IMAGE_TAG=""

# Optional: set to 1 to rotate the backup key on the next `backup`.
# ROTATE=""
